@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if("@CMAKE_SYSTEM_NAME@" STREQUAL "Linux")
  find_dependency(Threads)
  find_library(LIB_RT rt)
elseif("@CMAKE_SYSTEM_NAME@" STREQUAL "Darwin")
  # macOS: pthread and socket APIs are provided by libSystem — no extra dependencies.
elseif("@CMAKE_SYSTEM_NAME@" STREQUAL "Windows")
  # Windows: ws2_32 is resolved via the exported targets file — no extra find_dependency needed.
endif()

if(@XPROC_EXPORT_WITH_NLOHMANN_JSON@)
  find_dependency(nlohmann_json CONFIG)
endif()
if(@XPROC_EXPORT_WITH_PROTOBUF@)
  find_dependency(Protobuf)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/xprocTargets.cmake")
